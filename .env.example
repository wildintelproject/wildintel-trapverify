# CamTrap Verify — example configuration
#
# Copy this file to one of the locations below and rename it to .env:
#   ~/.config/camtrap_verify/.env   (user config, highest priority)
#   backend/src/.env                (project-local fallback)
#
# All values shown are the defaults — only set what you need to override.
#
# PORTS
# ─────
# There are two ports in play:
#   • Backend API  → CAMTRAP_PORT below (env var, read by FastAPI/Uvicorn)
#   • Frontend dev → passed as a CLI flag, not an env var:
#       uv run cli dev --frontend-port 5173
#       uv run cli frontend dev --port 5173
#
# If you change either port, update CAMTRAP_CORS_ORIGINS accordingly so the
# browser can reach the API without CORS errors.

# ── Backend API ───────────────────────────────────────────────────────────────
CAMTRAP_PORT=8765
CAMTRAP_LOG_LEVEL=INFO         # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ── CORS (must include the frontend origin) ───────────────────────────────────
# Default covers the Vite dev server (5173) and the backend itself (8765).
CAMTRAP_CORS_ORIGINS=["http://localhost:5173","http://localhost","http://localhost:8765"]

# ── Paths ─────────────────────────────────────────────────────────────────────
# CAMTRAP_APP_DIR=/home/user/.config/camtrap_verify
# CAMTRAP_DEFAULT_OUTPUT_DIR=/home/user/Documents/camtrap_verify
