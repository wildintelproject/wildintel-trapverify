# CamTrap Verify — backend configuration
# Copy this file to .env and edit as needed.
# All variables are optional; the defaults work out of the box.

# Port the uvicorn server listens on
CAMTRAP_PORT=8765

# Python log level for the application code (DEBUG, INFO, WARNING, ERROR, CRITICAL)
CAMTRAP_LOG_LEVEL=INFO

# Allowed CORS origins (JSON list)
CAMTRAP_CORS_ORIGINS=["http://localhost:5173","http://localhost","http://localhost:8765"]

# Where to store the active session pointer
# CAMTRAP_APP_DIR=/home/user/.config/camtrap_verify

# Default base directory for session output
# CAMTRAP_DEFAULT_OUTPUT_DIR=/home/user/Documents/camtrap_verify
